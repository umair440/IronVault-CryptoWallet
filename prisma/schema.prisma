generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DEVELOPER
  BEGINNER_TRADER
  GENERIC_TRADER
}

enum TransactionStatus {
  DRAFT
  PENDING
  SUBMITTED
  FAILED
  CANCELLED
}

enum TransactionDirection {
  SEND
  RECEIVE
}

enum SecretType {
  RECOVERY_PHRASE
  IMPORTED_PRIVATE_KEY
}

model User {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  username         String        @unique
  email            String        @unique
  mobileNumber     String?
  passwordHash     String
  role               UserRole      @default(BEGINNER_TRADER)
  emailNotifications Boolean       @default(false)
  sessions           Session[]
  wallets          Wallet[]
  contacts         Contact[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Session {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash  String   @unique
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String   @db.ObjectId
  createdAt  DateTime @default(now())
}

model Wallet {
  id                        String        @id @default(auto()) @map("_id") @db.ObjectId
  name                      String
  encryptedRecoveryPhrase   String
  network                   String
  addresses                 WalletAddress[]
  transactions              Transaction[]
  vault                     EncryptedWalletVault?
  balances                  Balance[]
  owner                     User          @relation(fields: [ownerId], references: [id])
  ownerId                   String        @db.ObjectId
  createdAt                 DateTime      @default(now())
}

model Balance {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  wallet      Wallet   @relation(fields: [walletId], references: [id])
  walletId    String   @db.ObjectId
  assetSymbol String
  network     String
  amount      Float    @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([walletId, assetSymbol, network])
}

model EncryptedWalletVault {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  wallet          Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  walletId        String           @unique @db.ObjectId
  vaultVersion    Int              @default(1)
  keyVersion      String
  recoverySecrets RecoverySecret[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([createdAt])
}

model RecoverySecret {
  id               String               @id @default(auto()) @map("_id") @db.ObjectId
  vault            EncryptedWalletVault @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  vaultId          String               @db.ObjectId
  secretType       SecretType
  label            String?
  encryptedPayload Json
  createdAt        DateTime             @default(now())

  @@index([vaultId, secretType])
  @@index([createdAt])
}

model WalletAddress {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  label     String
  address   String
  network   String
  wallet    Wallet   @relation(fields: [walletId], references: [id])
  walletId  String   @db.ObjectId
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  address   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String   @db.ObjectId
  createdAt DateTime @default(now())
}

model Transaction {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  assetSymbol      String
  amount           Float
  estimatedFee     Float
  recipientAddress String?
  senderAddress    String?
  network          String
  status           TransactionStatus
  direction        TransactionDirection
  txHash           String?
  riskWarning      String?
  wallet           Wallet            @relation(fields: [walletId], references: [id])
  walletId         String            @db.ObjectId
  createdAt        DateTime          @default(now())
}
